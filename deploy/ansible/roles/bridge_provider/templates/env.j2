# FILE: deploy/ansible/roles/bridge_provider/templates/env.j2

# Connectivity
NATS_URL={{ platform_endpoints.nats_url | default(lookup('env', 'NATS_URL'), true) | default('nats://192.168.100.200:4222', true) }}
REDIS_URL={{ redis_url | default(lookup('env', 'REDIS_URL'), true) | default('redis://192.168.100.200:6379', true) }}

# Postgres
POSTGRES_HOST={{ platform_endpoints.postgres_host | default(lookup('env', 'POSTGRES_HOST'), true) }}
POSTGRES_PORT={{ platform_endpoints.postgres_port | default(lookup('env', 'POSTGRES_PORT'), true) }}
POSTGRES_DB={{ postgres_db | default(lookup('env', 'POSTGRES_DB'), true) | default('factory_db', true) }}
POSTGRES_USER={{ postgres_user | default(lookup('env', 'POSTGRES_USER'), true) | default('factory_user', true) }}
POSTGRES_PASSWORD={{ postgres_password | default(lookup('env', 'POSTGRES_PASSWORD'), true) }}

# Deriv
DERIV_APP_ID={{ deriv_app_id | default(lookup('env', 'DERIV_APP_ID'), true) }}
DERIV_TOKEN={{ deriv_token | default(lookup('env', 'DERIV_TOKEN'), true) }}
DERIV_SYMBOLS={{ deriv_symbols | default(lookup('env', 'DERIV_SYMBOLS'), true) | default("R_10,R_25,R_50,R_75,R_100", true) }}

# Binance
BINANCE_API_KEY={{ binance_api_key | default(lookup('env', 'BINANCE_API_KEY'), true) }}
BINANCE_SECRET={{ binance_secret | default(lookup('env', 'BINANCE_SECRET'), true) }}

# Health
HEALTH_PORT={{ bridge_health_port | default(lookup('env', 'HEALTH_PORT'), true) | default(8080, true) }}