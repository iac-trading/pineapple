import os
import sys
import logging
from flask_appbuilder.security.manager import AUTH_OAUTH
from airflow.www.security import AirflowSecurityManager

log = logging.getLogger(__name__)

# ----------------------------------------------------
# AUTHENTIK OIDC CONFIGURATION
# ----------------------------------------------------
AUTH_TYPE = AUTH_OAUTH
AUTH_USER_REGISTRATION = True
AUTH_USER_REGISTRATION_ROLE = "Viewer"

OAUTH_PROVIDERS = [
    {
        "name": "authentik",
        "icon": "fa-lock",
        "token_key": "access_token",
        "remote_app": {
            "client_id": os.getenv("AIRFLOW_AUTHENTIK_CLIENT_ID"),
            "client_secret": os.getenv("AIRFLOW_AUTHENTIK_CLIENT_SECRET"),
            "api_base_url": "http://10.100.100.201:9333/application/o/",
            "client_kwargs": {
                "scope": "openid email profile",
            },
            "server_metadata_url": "http://10.100.100.201:9333/application/o/airflow/.well-known/openid-configuration",
            "access_token_url": "http://10.100.100.201:9333/application/o/token/",
            "authorize_url": "http://10.100.100.201:9333/application/o/authorize/",
            "userinfo_endpoint": "http://10.100.100.201:9333/application/o/userinfo/",
        },
    },
]

class HybridSecurityManager(AirflowSecurityManager):
    def get_oauth_user_info(self, provider, resp):
        if provider == 'authentik':
            # Intentamos obtener la información del usuario (con barra final / obligatoria)
            remote = self.appbuilder.sm.oauth_remotes[provider]
            userinfo_res = remote.get('userinfo/')
            
            if userinfo_res.status_code != 200:
                log.error(f"LOG_ERROR_OIDC: Status {userinfo_res.status_code} - Content: {userinfo_res.text}")
                return {}

            try:
                user_data = userinfo_res.json()
            except Exception as e:
                log.error(f"Failed to parse userinfo JSON: {str(e)}")
                return {}

            return {
                'username': user_data.get('preferred_username', user_data.get('nickname', user_data.get('sub'))),
                'email': user_data.get('email'),
                'first_name': user_data.get('given_name', user_data.get('name', user_data.get('preferred_username', 'Authentik'))),
                'last_name': user_data.get('family_name', user_data.get('nickname', 'User')),
            }
        return super().get_oauth_user_info(provider, resp)

SECURITY_MANAGER_CLASS = HybridSecurityManager
