AIRFLOW__CORE__EXECUTOR={{ airflow_executor }}
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=True
AIRFLOW__API__AUTH_BACKENDS=airflow.api.auth.backend.basic_auth,airflow.api.auth.backend.session

# Security (Infisical Injection fallback)
{% set _env_fernet = lookup('env', 'AIRFLOW_FERNET_KEY') %}
AIRFLOW__CORE__FERNET_KEY={{ _env_fernet if _env_fernet | length == 44 else airflow_fernet_key }}
AIRFLOW__WEBSERVER__SECRET_KEY={{ lookup('env', 'AIRFLOW_WEBSERVER_SECRET_KEY') | default(infisical_auth_secret, true) }}

# Celery (Redis) + DB metadata
AIRFLOW__CELERY__BROKER_URL={{ redis_url | default(lookup('env', 'REDIS_URL')) }}
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://{{ postgres_user }}:{{ lookup('env', 'PLATFORM_POSTGRES_PASSWORD') | default(postgres_password, true) }}@{{ platform_endpoints.postgres_host }}:{{ platform_endpoints.postgres_port }}/{{ postgres_db }}

AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://{{ postgres_user }}:{{ lookup('env', 'PLATFORM_POSTGRES_PASSWORD') | default(postgres_password, true) }}@{{ platform_endpoints.postgres_host }}:{{ platform_endpoints.postgres_port }}/{{ postgres_db }}

# Airflow Connections
AIRFLOW_CONN_PLATFORM_DB={{ lookup('env', 'AIRFLOW_CONN_PLATFORM_DB') | default('postgresql+psycopg2://' ~ postgres_user ~ ':' ~ postgres_password ~ '@' ~ platform_endpoints.postgres_host ~ ':' ~ platform_endpoints.postgres_port ~ '/' ~ postgres_db, true) }}

# NATS
NATS_URL={{ lookup('env', 'NATS_URL') | default(platform_endpoints.nats_url, true) }}
PLATFORM_PG_CONN_ID=platform_db

# Admin UI
AIRFLOW_ADMIN_USER={{ lookup('env', 'AIRFLOW_ADMIN_USER') | default('admin', true) }}
AIRFLOW_ADMIN_PASSWORD={{ lookup('env', 'AIRFLOW_ADMIN_PASSWORD') | default(airflow_admin_password, true) }}

# Authentik OIDC (Infisical)
AIRFLOW_AUTHENTIK_CLIENT_ID="{{ lookup('env', 'AIRFLOW_AUTHENTIK_CLIENT_ID') | default('airflow-sso', true) }}"
AIRFLOW_AUTHENTIK_CLIENT_SECRET="{{ lookup('env', 'AIRFLOW_AUTHENTIK_CLIENT_SECRET') | default('airflow_auth_secret_2026', true) }}"
AIRFLOW__WEBSERVER__WEB_SERVER_CONFIG=/opt/airflow/webserver_config.py
AIRFLOW__WEBSERVER__BASE_URL=http://10.100.100.201:8080