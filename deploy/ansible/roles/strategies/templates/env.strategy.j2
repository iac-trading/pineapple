# Auto-generated by Ansible (strategies)
# Strategy: {{ st.id }} - {{ st.name | default('Unnamed') }}

# --- Identidad V3 ---
INSTANCE_ID={{ st.instance_id | default('101e0000-0000-0000-0000-0000000' + (st.id | string).zfill(5)) }}
BLUEPRINT_ID={{ st.id }}

# --- Endpoints y Seguridad (Desde Vault) ---
NATS_URL=nats://{{ nats_user }}:{{ nats_password }}@{{ nats_host | default('192.168.100.200') }}:{{ nats_port | default(4222) }}
REDIS_URL={{ redis_url | default(platform_endpoints.redis_url) }}
POSTGRES_HOST={{ platform_endpoints.postgres_host }}
POSTGRES_PORT={{ platform_endpoints.postgres_port }}
POSTGRES_DB={{ postgres_db }}
POSTGRES_USER={{ postgres_user }}
POSTGRES_PASSWORD={{ postgres_password }}

# --- Meta Data de la Estrategia ---
STRATEGY_ID={{ st.id }}
STRATEGY_NAME={{ st.name }}
SYMBOL={{ st.symbol }}
TIMEFRAME={{ st.timeframe | default('tick') }}
BROKER={{ st.broker | default('deriv') }}
QTY={{ st.qty | default('1.0') }}

# --- Sujetos NATS ---
MARKET_SUBJECT={{ st.md_subject | default('md.' + (st.broker | default('deriv')) + '.' + (st.symbol | replace(' ', '_')) + '.tick') }}
ORDERS_SUBJECT={{ st.orders_subject | default('orders.intent') }}

# --- Parámetros Específicos ---
{% if st.params is defined and st.params is mapping %}
{% for k, v in st.params.items() %}
{{ k | upper }}={{ v }}
{% endfor %}
{% endif %}
