# =================================================================
# ENTORNO DE ESTRATEGIA - FACTORY V2.0 (DINÁMICO)
# =================================================================

# --- Identidad de la Instancia ---
INSTANCE_ID={{ instance_id }}
BLUEPRINT_ID={{ blueprint_id }}
ASSIGNED_HOST={{ inventory_hostname }}

# --- Mensajería NATS (Conexión al nodo BRAIN) ---
NATS_URL=nats://{{ nats_user }}:{{ nats_password }}@{{ nats_host | default('192.168.100.200') }}:{{ nats_port | default(4222) }}

# --- Base de Datos (Conexión al nodo DATA) ---
POSTGRES_HOST={{ platform_endpoints.postgres_host }}
POSTGRES_PORT={{ platform_endpoints.postgres_port }}
POSTGRES_DB={{ postgres_db }}
POSTGRES_USER={{ postgres_user }}
POSTGRES_PASSWORD={{ postgres_password }}

# --- Broker y CCXT ---
# Se activa CCXT por defecto para flexibilidad total
USE_CCXT=true
BROKER_TYPE={{ broker | default('deriv') }}

# Credenciales dinámicas según broker
{% if broker == 'deriv' %}
DERIV_TOKEN={{ deriv_token }}
DERIV_APP_ID={{ deriv_app_id }}
{% elif broker == 'ibkr' %}
IBKR_HOST={{ hostvars[infra_hosts.trade].ansible_host }}
IBKR_PORT=4001
{% endif %}

# --- Observabilidad ---
LOG_LEVEL=INFO
METRICS_ENABLED=true