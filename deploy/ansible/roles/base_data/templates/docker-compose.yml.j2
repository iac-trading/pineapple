version: "3.9"

networks:
  {{ docker_network_name }}:
    external: true

volumes:
  timescale_data:

services:
  timescaledb:
    image: timescale/timescaledb:2.15.3-pg16
    container_name: timescaledb_10_base
    restart: unless-stopped
    networks: [ "{{ docker_network_name }}" ]
    env_file: [ .env ]
    ports:
      - "{{ postgres_port }}:5432"
    volumes:
      - timescale_data:/var/lib/postgresql/data
      - ./schema_v3.sql:/docker-entrypoint-initdb.d/schema_v3.sql:ro
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ timescaledb_user }} -d {{ timescaledb_db }}"]
      interval: 10s
      timeout: 5s
      retries: 5

  adminer:
    image: adminer:4.8.1
    container_name: adminer_10_base
    restart: unless-stopped
    networks: [ "{{ docker_network_name }}" ]
    ports:
      - "{{ adminer_port }}:8080"
    environment:
      - ADMINER_DEFAULT_SERVER=timescaledb

  postgres_exporter:
    image: prometheuscommunity/postgres-exporter:v0.15.0
    container_name: postgres_exporter_10_base
    restart: unless-stopped
    networks: [ "{{ docker_network_name }}" ]
    ports:
      - "9187:9187"
    environment:
      - DATA_SOURCE_NAME=postgresql://{{ timescaledb_user }}:{{ timescaledb_password }}@timescaledb:5432/{{ timescaledb_db }}?sslmode=disable